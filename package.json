{
  "name": "peer-review-mcp",
  "version": "0.1.0",
  "description": "MCP broker for read-only peer review between Codex and Claude Code.",
  "type": "module",
  "bin": {
    "peer-review-mcp": "./dist/index.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "bun test",
    "dev": "bun src/index.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  }
}
