{
  "name": "peer-cli-mcp",
  "version": "0.1.0",
  "description": "MCP bridge for calling local coding-agent CLIs such as Codex and Claude Code.",
  "type": "module",
  "license": "MIT",
  "author": "domucchi",
  "homepage": "https://github.com/domucchi/peer-cli-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domucchi/peer-cli-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/domucchi/peer-cli-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "codex",
    "claude-code",
    "agent-cli",
    "subagent",
    "code-review"
  ],
  "packageManager": "bun@1.3.13",
  "bin": {
    "peer-cli-mcp": "./dist/index.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "bun test",
    "dev": "bun src/index.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  }
}
